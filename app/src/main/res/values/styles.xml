<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Text" parent="@android:style/Widget" />
    <style name="Chip" parent="@android:style/Widget" />

    <style name="Text.Title">
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/home_primary</item>
    </style>

    <style name="Text.H1">
        <item name="android:textSize">@dimen/text_h1</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/home_primary</item>
    </style>

    <style name="Text.Body">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/home_primary</item>
    </style>

    <style name="Text.BodyMuted">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/home_secondary</item>
    </style>

    <style name="Text.Caption">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Chip.Text">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
    </style>
</resources>
