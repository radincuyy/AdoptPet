<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/category_row"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <TextView
        android:id="@+id/tv_category_all"
        style="@style/Chip.Text"
        android:layout_width="112dp"
        android:layout_height="42dp"
        android:background="@drawable/bg_chip_active"
        android:text="@string/home_category_all"
        android:textColor="@android:color/white" />

    <TextView
        android:id="@+id/tv_category_cat"
        style="@style/Chip.Text"
        android:layout_width="118dp"
        android:layout_height="42dp"
        android:layout_marginStart="14dp"
        android:background="@drawable/bg_chip_inactive"
        android:text="@string/home_category_cat"
        android:textColor="@color/home_primary" />

    <TextView
        android:id="@+id/tv_category_dog"
        style="@style/Chip.Text"
        android:layout_width="118dp"
        android:layout_height="42dp"
        android:layout_marginStart="14dp"
        android:background="@drawable/bg_chip_inactive"
        android:text="@string/home_category_dog"
        android:textColor="@color/home_primary" />

</LinearLayout>
